{
  "id": "council-os",
  "name": "Council OS",
  "version": "1.0.0",
  "description": "Multi-model deliberation and Solo Mode",
  "category": "council",
  "icon": "council",
  "status": "active",
  "capabilities": ["launch", "health"],
  "dependencies": {
    "services": ["ollama"]
  },
  "launch": {
