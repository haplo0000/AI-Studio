{
  "name": "ai-studio",
  "version": "0.1.0",
  "description": "AI Studio — local AI workstation control plane (Phase 2A)",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite --port 5174 --strictPort",
    "dev:electron": "wait-on http://127.0.0.1:5174 && cross-env NODE_ENV=development electron .",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "start": "cross-env NODE_ENV=production electron .",
    "preview": "vite preview --port 5174",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run && node scripts/applicationMenu.test.cjs && node scripts/videoQualityPresets.test.cjs",
    "test:watch": "vitest",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "js-yaml": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^36.4.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "jsdom": "^26.1.0",
    "wait-on": "^8.0.3"
  }
}
